# Server runtime
PORT=3001
NODE_ENV=development

# Frontend origins (no trailing slash)
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated list of allowed origins
# FRONTEND_URLS=http://localhost:3000,http://localhost:5173

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar

# AI
GOOGLE_API_KEY=your_google_ai_api_key

# Database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=time
# Hosted MySQL providers like Aiven typically require TLS
MYSQL_SSL=false
MYSQL_SSL_REJECT_UNAUTHORIZED=true

# Session / cookies
# REQUIRED — server will refuse to start if this is missing.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=replace_with_a_long_random_secret
COOKIE_SAME_SITE=lax
